# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_KEY=sk-or-v1-...

# Model to use via OpenRouter (defaults to claude-sonnet-4-6)
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# LinkedIn credentials for browser automation
# WARNING: Using Playwright to automate LinkedIn violates their Terms of Service.
# Use only for personal productivity and at your own risk.
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=yourpassword

# Optional: Daemon check interval in minutes (default: 5)
EMAIL_CHECK_INTERVAL_MINUTES=5
